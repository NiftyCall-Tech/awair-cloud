# Copy to `.env.local` (never commit secrets).

# Required for live Awair Cloud API calls (Bearer token from https://developer.getawair.com/)
AWAIR_ACCESS_TOKEN=

# Alias — if set, used when AWAIR_ACCESS_TOKEN is empty
# AWAIR_BEARER_TOKEN=

# Optional: defaults shown
AWAIR_API_BASE_URL=https://developer-apis.awair.is/v1
AWAIR_USER_SEGMENT=users/self

# Pin a device when you own more than one (matches Awair API path segments)
# AWAIR_DEVICE_TYPE=awair-element
# AWAIR_DEVICE_ID=12345

# Set to "true" for deterministic UI without a token (CI, screenshots, local onboarding)
AWAIR_DEMO_MODE=false

# History limits (Awair caps: 5-min ≤288, 15-min ≤672). Defaults fetch full windows for charts.
# AWAIR_HISTORY_5MIN_LIMIT=288
# AWAIR_HISTORY_15MIN_LIMIT=672

# Optional: fetch 1h raw air-data (extra quota) for denser sparklines when available
# AWAIR_FETCH_RAW_AIRDATA=false

# Server-side cache for air-data bundle (seconds). 0 = off. Default 60 — reduces duplicate Awair calls.
# AWAIR_AIRDATA_CACHE_SECONDS=60
